function reindexRows(fltid){

    $("#delayBody-" + fltid + " tr").each(function(index){

        var row = $(this);

        // Update all input/select names
        row.find(":input").each(function(){

            var name = $(this).attr("name");
            if(name){
                // Replace old index with new index
                var newName = name.replace(/delayDetailsNew\[\d+\]/, "delayDetailsNew[" + index + "]");
                $(this).attr("name", newName);
            }
        });

    });
}

