private String formatDropdownValue(String value) {
    if (value == null || value.isEmpty()) return value;

    char firstChar = Character.toUpperCase(value.charAt(0));

    // Convert to FULL-WIDTH Unicode (visually bigger)
    char bigChar = (char)(firstChar + 65248);

    String rest = value.substring(1);

    return bigChar + rest;
}

ArrayList<SelectionTO> processList = (ArrayList<SelectionTO>) getDelegate().getProcesses();

for (SelectionTO s : processList) {
    s.setValue(formatDropdownValue(s.getValue()));
}

setProcesses(processList);
