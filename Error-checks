private String formatDropdownValue(String value) {
    if (value == null || value.isEmpty()) return value;

    char firstChar = value.charAt(0);

    String cleanedValue;

    // Remove "A - " pattern if present
    if (value.length() > 3 && value.charAt(1) == ' ' && value.charAt(2) == '-') {
        cleanedValue = value.substring(3).trim();
    } else {
        cleanedValue = value.substring(1).trim();
    }

    return getFullWidthLetter(firstChar) + " " + cleanedValue;
}

private String getFullWidthLetter(char c) {
    if (c >= 'A' && c <= 'Z') {
        return String.valueOf((char)(c + 65248));
    }
    if (c >= 'a' && c <= 'z') {
        return String.valueOf((char)(Character.toUpperCase(c) + 65248));
    }
    return String.valueOf(c);
}


