function serialiseDiv(div) {
    if(!div) {
            return;
    }
    returnString ="";
    div = typeof div === "string" ? document.getElementById(div) : div;
    var elms = div.getElementsByTagName("*");
    for(var i = 0, maxI = elms.length; i < maxI; ++i) {
            var elm = elms[i];
            switch(elm.type) {
                case "text":
                case "textarea":
                case "hidden":
                case "select-one":
                    if(elm.name != 'undefined') {
                        if(TrimString(elm.value).length>0 ) {
                            returnString=returnString+"&"+escape(elm.name)+"="+escape(elm.value);
                        }
                    }                        
            }
    }
    return returnString;
}

