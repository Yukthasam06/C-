function addDelay(tag){
    //alert('id = '+$(this).attr('id'));
	var fltid = $(tag).attr('id').split("-")[1];
	//alert('fltid = '+fltid);
	var rowCount = $("#newDelayTable-"+fltid+" tr").length;
	//alert('rowcount = '+rowCount);
	if(rowCount > 1){
	    $("#newDelayTable-"+fltid+" tr:last").removeClass("ui-state-highlight");
	    var lastIndex = $("#newDelayTable-"+fltid+" tr:last").children(":nth-child(2)").children(":first").attr('name');
	    //alert('lastIndex = ' +lastIndex);
	    var newIndex = parseInt((lastIndex.split("[")[1]).split("]")[0]) + 1;
	    //alert('newIndex = ' +newIndex);
	    $("#newDelayTable-"+fltid+" tr:last").clone(true).insertAfter("#newDelayTable-"+fltid+" tr:last");
	    //alert('inserted');
	    $("#newDelayTable-"+fltid+" tr:last input").val("");

	    $("#newDelayTable-"+fltid+" tr:last").children().each(function(index) {
		$(this).children().each(function(ind){
		    var id = $(this).attr('id');
		    //alert('old id = '+id);
		    var newId = id.replace(new RegExp("_[0-9]{1,2}_"), "_"+newIndex+"_");
		    //alert('new id = '+newId);
		    var name = $(this).attr('name');
		    //alert('old name = '+name);
		    var newName = name.replace(new RegExp("\\[[0-9]{1,2}\\]"), "["+newIndex+"]");
		    //alert('new name = '+newName);
		    $(this).attr('id', newId);
		    $(this).attr('name', newName);
                    if(newId == 'processes'){
                        $(this).val(-1);
                    }
		});
	    });
	}else{
	    var url = "delayDtlsNewFirstRow.action?flightId=" + <s:property value="flightId"/>;
	    $.get(url, function(data){
		$('#delays-'+<s:property value="flightId"/>).html(data).show();
	    });
	}
	$("#newDelayTable-"+fltid+" tr:last").children(":nth-child(5)").text(" ");
	$("#newDelayTable-"+fltid+" tr:last").children(":nth-child(6)").text(" ");
	$("#newDelayTable-"+fltid+" tr:last").children(":nth-child(7)").children(":first").attr("id", "deleteDelay-0-0");
}

function loadReasons(processId, rowIndex){
    var reasonSelect = $("#reason_" + rowIndex);
    console.log("Dropdown ID:", "#reason_"+rowIndex);
    if(processId == -1){
        // Reset to default single option
        reasonSelect.html('<option value="-1">Select Reason</option>');
        return;
    }

    $.ajax({
        url: "loadReasons.action",
        type: "GET",
        data: {
            processId: processId
        },
        success: function(response){
            // Expecting response = options markup like <option value="1">Reason 1</option>...
            console.log("AJAX response:", response);  // Log response to browser console
            //alert("Response length: " + response);
            // Reset options first with default
            reasonSelect.html('<option value="-1">Select Reason</option>');
            
            // Append returned options
            reasonSelect.append(response);
        },
        error: function(){
            alert("Unable to load reasons");
            reasonSelect.html('<option value="-1">Select Reason</option>'); // reset on error too
        }
    });
}

function loadStakeholders(reasonId, rowIndex){
    var stakeholderSelect = $("#stakeholder_" + rowIndex);
    console.log("Dropdown ID:", "#stakeholder_"+rowIndex);
    console.log("ReasonId: "+reasonId);
    if(reasonId == -1){
        // Reset to default single option
        stakeholderSelect.html('<option value="-1">Select Stakeholder</option>');
        return;
    }

    $.ajax({
        url: "loadStakeholders.action",
        type: "GET",
        data: {
            reasonId: reasonId
        },
        success: function(response){
            console.log("AJAX response:", response);  // Log response to browser console
            //alert("Response length: " + response);
            // Reset options first with default
            stakeholderSelect.html('<option value="-1">Select Stakeholder</option>');
            
            // Append returned options
            stakeholderSelect.append(response);
        },
        error: function(){
            alert("Unable to load stakeholders");
            reasonSelect.html('<option value="-1">Select Stakeholder</option>'); // reset on error too
        }
    });
}

function loadDelayCode(stakeholderId, rowIndex) {
    var delayCodeField = $("#delayCode_" + rowIndex);
    if (stakeholderId == -1) {
        delayCodeField.val("");
        return;
    }

    $.ajax({
        url: "loadDelayCode.action",
        type: "GET",
        data: { stakeholderId: stakeholderId },
        success: function(response) {
            console.log("Delay code:", response);
            delayCodeField.val(response);
        },
        error: function() {
            alert("Unable to fetch delay code");
        }
    });
}

