<td width="9%">
    
    <!-- Hidden field for Struts binding -->
    <input type="hidden"
           name="delayDetailsNew[%{rowIndex}].processId"
           id="process_%{rowIndex}" />

    <!-- Dropdown UI -->
    <div class="custom-dropdown" data-row="%{rowIndex}">
        <div class="dropdown-selected">Select Process</div>

        <div class="dropdown-options">
            <s:iterator value="processes">
                <div class="dropdown-option"
                     data-value="<s:property value='id'/>">
                    
                    <span class="first-letter">
                        <s:property value="value.substring(0,1)"/>
                    </span>
                    <span class="rest-text">
                        <s:property value="value.substring(1)"/>
                    </span>

                </div>
            </s:iterator>
        </div>
    </div>

</td>

  .custom-dropdown {
    position: relative;
    width: 150px;
    cursor: pointer;
}

.dropdown-selected {
    padding: 5px;
    border: 1px solid #ccc;
    background: #fff;
}

.dropdown-options {
    display: none;
    position: absolute;
    background: #fff;
    border: 1px solid #ccc;
    width: 100%;
    max-height: 200px;
    overflow-y: auto;
    z-index: 1000;
}

.dropdown-option {
    padding: 5px;
}

.dropdown-option:hover {
    background: #eee;
}

/* 🔥 First letter styling */
.first-letter {
    font-size: 16px;
    font-weight: bold;
}

.rest-text {
    font-size: 12px;
}

$(document).on("click", ".dropdown-selected", function(){
    $(this).siblings(".dropdown-options").toggle();
});

$(document).on("click", ".dropdown-option", function(){

    var option = $(this);
    var dropdown = option.closest(".custom-dropdown");
    var row = option.closest("tr");

    var value = option.data("value");
    var text = option.text();

    // Set visible text
    dropdown.find(".dropdown-selected").text(text);

    // Set hidden input (IMPORTANT for Struts)
    row.find("input[name$='.processId']").val(value);

    // Close dropdown
    dropdown.find(".dropdown-options").hide();

    // 🔥 Trigger dependent dropdown
    loadReasons(row.find("input[name$='.processId']")[0]);

});
