
function addDelay(tag){

    var fltid = $(tag).attr('id').split("-")[1];

    var rowCount = $("#newDelayTable-"+fltid+" tr").length - 1;

    $.ajax({

        url: "delayDtlsNewFirstRow.action",
        type: "GET",

        data:{
            flightId: fltid,
            rowIndex: rowCount
        },

        success:function(response){

            $("#newDelayTable-"+fltid+" tbody").append(response);

        },

        error:function(){
            alert("Unable to add new delay row");
        }

    });
}



function loadReasons(processId,rowIndex){

    var reasonSelect=$("#reason_"+rowIndex);

    if(processId==-1){
        reasonSelect.html('<option value="-1">Select Reason</option>');
        return;
    }

    $.ajax({

        url:"loadReasons.action",
        type:"GET",

        data:{
            processId:processId
        },

        success:function(response){

            reasonSelect.empty();
            reasonSelect.append('<option value="-1">Select Reason</option>');
            reasonSelect.append(response);

        },

        error:function(){
            alert("Unable to load reasons");
        }

    });

}



function loadStakeholders(reasonId,rowIndex){

    var stakeholderSelect=$("#stakeholder_"+rowIndex);

    if(reasonId==-1){
        stakeholderSelect.html('<option value="-1">Select Stakeholder</option>');
        return;
    }

    $.ajax({

        url:"loadStakeholders.action",
        type:"GET",

        data:{
            reasonId:reasonId
        },

        success:function(response){

            stakeholderSelect.empty();
            stakeholderSelect.append('<option value="-1">Select Stakeholder</option>');
            stakeholderSelect.append(response);

        },

        error:function(){
            alert("Unable to load stakeholders");
        }

    });

}



function loadDelayCode(stakeholderId,rowIndex){

    var delayCodeField=$("#delayCode_"+rowIndex);

    if(stakeholderId==-1){
        delayCodeField.val("");
        return;
    }

    $.ajax({

        url:"loadDelayCode.action",
        type:"GET",

        data:{
            stakeholderId:stakeholderId
        },

        success:function(response){

            delayCodeField.val(response);

        },

        error:function(){
            alert("Unable to fetch delay code");
        }

    });

}



function deleteDelay(tag){

    if(confirm('Are you sure you want to delete?')){

        $(tag).closest("tr").remove();

    }

}


