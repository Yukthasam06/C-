 private ArrayList<String> getDeletedDelayIds(ArrayList<DelayDetailTO> oldDelays, ArrayList<DelayDetailTO> newDelays){
        ArrayList<String> deltedIds = new ArrayList<String>();
        ArrayList<String> newIds = new ArrayList<String>();
        for (DelayDetailTO newDdly: newDelays) {
            //System.out.println("New Delays ***************************** "+newDdly);
            if(newDdly != null)
                newIds.add(newDdly.getDelayId());
        }
        for (DelayDetailTO oldDly: oldDelays) {
            if(!newIds.contains(oldDly.getDelayId())){
                deltedIds.add(oldDly.getDelayId());
            }
        }
       // System.out.println("Deleted IDs "+deltedIds);
        return deltedIds;
    }

private boolean changeInValue(String first, String second) {
        if ((first == null || "".equals(first.trim())) && 
            (second == null || "".equals(second.trim()))) {
            return false;
        } else if ((first == null || "".equals(first.trim()))) {
            return true;
        } else {
            return !first.equals(second);
        }
    }
