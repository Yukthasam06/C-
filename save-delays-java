public String saveDelayDtls() throws FileNotFoundException, IOException {
       // System.out.println("in1 saveDelayDtls() .. flightId = " + flightId);
        int len = getFlightId().split(",").length - 1;
        setFlightId(getFlightId().split(",")[0]);
       // System.out.println("in saveDelayDtls()");
        ArrayList<DelayDetailTO> addDelayDtls = new ArrayList<DelayDetailTO>();
        ArrayList<DelayDetailTO> updDelayDtls = new ArrayList<DelayDetailTO>();
        ArrayList<String> deleteDelayIds = new ArrayList<String>();
        ArrayList<DelayDetailTO> origDelayDtls = 
            new ArrayList<DelayDetailTO>();
         try {
        
            if("error".equals(initPage()) || !serverValidate()){
                return "error";
            }        
        
            origDelayDtls = 
                    (ArrayList<DelayDetailTO>)getDelegate().getFlightDelayDetails(getFlightId());
                        
            
            deleteDelayIds = getDeletedDelayIds(origDelayDtls,getDelayDetails());
             for (DelayDetailTO dtl: getDelayDetails()) {
                if (dtl != null) {
                
                    if (dtl.getDelayId() == null || 
                        "".equals(dtl.getDelayId().trim())) {
                    	dtl.setIsnew(true);
                        addDelayDtls.add(dtl);
                       // System.out.println("delay detail added by " + 
                         //                  getUserTO().getUserId());
                    } else {
                        if (origDelayDtls.contains(dtl)) {
                            int index = origDelayDtls.indexOf(dtl);
                            DelayDetailTO origDelayDtl = 
                                origDelayDtls.get(index);
                            boolean isDirty = false;
                            if (changeInValue(dtl.getDelayMinutes(), 
                                              origDelayDtl.getDelayMinutes())) {
                                isDirty = true;
                                dtl.setActivityLog(new ActivityLogTO("DELAY_UPD ("+dtl.getDelayCode()+")", 
                                                                     "Delay minutes updated", 
                                                                     "Delay minute changed from " + 
                                                                     origDelayDtl.getDelayMinutes() + 
                                                                     " to " + 
                                                                     dtl.getDelayMinutes()+
                                                                     " for delay code " + dtl.getDelayCode(),   
                                                                     "OTP", 
                                                                     getUserTO().getUserId()));
                            }
                            if (changeInValue(dtl.getAccountSecStn(), 
                                              origDelayDtl.getAccountSecStn())) {
                                isDirty = true;
                                dtl.setActivityLog(new ActivityLogTO("DELAY_UPD ("+dtl.getDelayCode()+")", 
                                                                     "Delay section updated", 
                                                                     "Delay section changed from " + 
                                                                     origDelayDtl.getAccountSecStn() + 
                                                                     " to " + 
                                                                     dtl.getAccountSecStn()+
                                                                     " for delay code " + dtl.getDelayCode(),  
                                                                     "OTP", 
                                                                     getUserTO().getUserId()));
                            }
                            if (changeInValue(dtl.getDelayRemarks(), 
                                              origDelayDtl.getDelayRemarks())) {
                                isDirty = true;
                                dtl.setActivityLog(new ActivityLogTO("DLY_UPD ("+dtl.getDelayCode()+")", 
                                                                     "Delay remarks updated", 
                                                                     "Delay remarks changed from " + 
                                                                     origDelayDtl.getDelayRemarks() + 
                                                                     " to " + 
                                                                     dtl.getDelayRemarks() +
                                                                     " for delay code " + dtl.getDelayCode(), 
                                                                     "OTP", 
                                                                     getUserTO().getUserId()));
                            }
                            if (isDirty) {
                                updDelayDtls.add(dtl);
                            } 
                        } else {
                            String updDelayCode = "";
                            for (DelayDetailTO dtlTO: origDelayDtls) {
                                if (dtlTO.getDelayId().equals(dtl.getDelayId())) {
                                    updDelayCode = dtlTO.getDelayCode();
                                }
                            }
                            getDelegate().deleteDelay(getFlightId(), 
                                                      dtl.getDelayId(), 
                                                      getUserTO());

                            dtl.setIsnew(false);
                            addDelayDtls.add(dtl);
                        }
                    }
                }
            }
            getDelegate().saveDelayDetails(getFlightId(), addDelayDtls, 
                                           updDelayDtls, getUserTO());
            deleteAllDelays(getFlightId(),deleteDelayIds);
            fetchDelays(getFlightId());       
            setDelayCodes((ArrayList<SelectionTO>)getDelegate().getValidDelayCodes(flightId));
           // getFlightHandler().saveDelayDetails(getDelayDetails(), getFlightId(), getUserTO().getUserId());
        } catch (OtpException e) {
            e.printStackTrace();
        }catch(Exception e){
        	e.printStackTrace();
        	
        }
        return "success";        
    }

