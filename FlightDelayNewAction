	public String loadStakeholders() {
		 
	    try {
	        List<StakeholderTO> list = (ArrayList<StakeholderTO>)getDelegate().getStakeholders(reasonId);
	        Map<String, List<StakeholderTO>> grouped = new LinkedHashMap<>();
	 
	        for (StakeholderTO s : list) {
	            if (!grouped.containsKey(s.getStakeholderName())) {
	                grouped.put(s.getStakeholderName(), new ArrayList<StakeholderTO>());
	            }
	            grouped.get(s.getStakeholderName()).add(s);
	        }
	        StringBuilder html = new StringBuilder();
	        for (Map.Entry<String, List<StakeholderTO>> entry : grouped.entrySet()) {
	 
	            List<StakeholderTO> subList = entry.getValue();
	            boolean hasSubgroup = subList.get(0).getStakeholderSubgroup() != null;
	            if (hasSubgroup) {
	                String stakeholderName = entry.getKey();
	                if(stakeholderName.contains("-")) {
	                	stakeholderName = stakeholderName.split("-")[1].trim();
	                }
	                html.append("<optgroup label=\"")
	                    .append(stakeholderName)
	                    .append("\">");
	 
	                for (StakeholderTO s : subList) {
	                    html.append("<option value=\"")
	                        .append(s.getStakeholderId())
	                        .append("\">")
	                        .append(s.getStakeholderSubgroup())
	                        .append("</option>");
	                }
	 
	                html.append("</optgroup>"); 
	            } else {
	                StakeholderTO s = subList.get(0);
	 
	                html.append("<option value=\"")
	                    .append(s.getStakeholderId())
	                    .append("\">")
	                    .append(s.getStakeholderName())
	                    .append("</option>");
	            }
	        }
	 
	        HttpServletResponse response = ServletActionContext.getResponse();
	        response.setContentType("text/html");
	        response.getWriter().write(html.toString());
	 
	    } catch (Exception e) {
	        e.printStackTrace();
	    }	 
	    return null;
	}
	 
