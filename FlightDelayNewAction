	public String saveDelayDtlsNew() {

	    try {

	        //Prepare flightId
	        setFlightId(getFlightId().split(",")[0]);

	        if ("error".equals(initPage()) || !serverValidate()) {
	            return "error";
	        }

	        ArrayList<DelayDetailNewTO> newList = getDelayDetailsNew();

	        ArrayList<DelayDetailNewTO> existingList =
	            (ArrayList<DelayDetailNewTO>) getDelegate()
	                .getDelayDetailsNew(getFlightId());

	        Map<String, DelayDetailNewTO> existingMap = new HashMap<>();

	        for (DelayDetailNewTO old : existingList) {
	            existingMap.put(old.getDelayId(), old);
	        }

	        List<DelayDetailNewTO> insertList = new ArrayList<>();
	        List<DelayDetailNewTO> updateList = new ArrayList<>();
	        Set<String> processedIds = new HashSet<>();

	        for (DelayDetailNewTO dtl : newList) {

	            if (dtl == null) continue;

	            // Skip empty row
	            /*if (dtl.getProcessId() == null || "-1".equals(dtl.getProcessId())) {
	                continue;
	            }*/

	            dtl.setFlightId(getFlightId());

	            // NEW ROW
	            if (dtl.getDelayId() == null || dtl.getDelayId().trim().isEmpty()) {
	                insertList.add(dtl);
	            }

	            // EXISTING ROW
	            else {

	                DelayDetailNewTO old = existingMap.get(dtl.getDelayId());

	                if (old != null) {

	                    processedIds.add(dtl.getDelayId());

	                    // CHECK IF MODIFIED
	                    if (isModified(dtl, old)) {

	                        // Soft delete old
	                        /*getDelegate().deleteNewDelay(
	                                old.getDelayId(),
	                                getUserTO().getUserId()
	                        );*/

	                        // Updated delays
	                        updateList.add(dtl);
	                    }
	                }
	            }
	        }

	        for (DelayDetailNewTO old : existingList) {

	            if (!processedIds.contains(old.getDelayId())) {

	                getDelegate().deleteNewDelay(
	                        old.getDelayId(),
	                        getUserTO().getUserId()
	                );
	            }
	        }

	        if (!insertList.isEmpty() || !updateList.isEmpty()) {
	            getDelegate().saveDelayDetailsNew(getFlightId(), insertList, updateList, getUserTO());
	        }
            System.out.println("NewDelayDetails: "+existingList.toString());

            //Refresh data
            setProcesses((ArrayList<SelectionTO>)getDelegate().getProcesses());  
	        fetchDelays(getFlightId());

	    } catch (Exception e) {
	        e.printStackTrace();
	        return "error";
	    }

	    return "success";
	}
	
	private boolean isModified(DelayDetailNewTO newObj, DelayDetailNewTO oldObj) {

	    return !safeEquals(newObj.getProcessId(), oldObj.getProcessId()) ||
	           !safeEquals(newObj.getReasonId(), oldObj.getReasonId()) ||
	           !safeEquals(newObj.getStakeholderId(), oldObj.getStakeholderId()) ||
	           !safeEquals(newObj.getDelayCode(), oldObj.getDelayCode()) ||
	           !safeEquals(newObj.getDelayMinutes(), oldObj.getDelayMinutes()) ||
	           !safeEquals(newObj.getType(), oldObj.getType()) ||
	           !safeEquals(newObj.getDelayRemarks(), oldObj.getDelayRemarks());
	}
	
	private boolean safeEquals(String a, String b) {

	    if ((a == null || a.trim().isEmpty()) &&
	        (b == null || b.trim().isEmpty())) {
	        return true;
	    }

	    if (a == null || b == null) {
	        return false;
	    }

	    return a.equals(b);
	}
	
	private void fetchDelays(String flightId) throws OtpException, 
                                                     FileNotFoundException, 
                                                     IOException {
		ArrayList<DelayDetailNewTO> delayTOs = 
	    (ArrayList<DelayDetailNewTO>)getDelegate().getFlightDelaysNew(flightId);
		
		setDelayDetailsNew(delayTOs);
		
		setFreezeStatus(getDelegate().getFreezeStatus(flightId));
	}
	
	private boolean serverValidate() throws OtpException {
        boolean valid = true;

        //check for duplicate delay codes
        HashSet<String> set = new HashSet<String>();
        for(DelayDetailNewTO to : getDelayDetailsNew()) {
	        if(to!=null){        
	            boolean val = set.add(to.getDelayCode());
	            if (val == false) {
	                setErrorMessage("Multiple entries for the delay code "+to.getDelayCode()+ " exists!!");
	                return false;
	            }
            }
        }
        return valid;
    }
	
	private String initPage() {
        try {
            setUserTO((UserTO)servletRequest.getSession().getAttribute(PaxConstants.ATTR_USER_TO));
            if (getUserTO() != null) {
                UserPermissionTo userPermissionTo = 
                    getUserTO().getUserPermissionTo();

                ArrayList<String> pFromStations = 
                    (ArrayList<String>)userPermissionTo.getFilterValues(PrivileageConstants.PAX_TRG_FLIGHT, 
                                                                        PrivileageConstants.PAX_ACT_VIEW, 
                                                                        PrivileageConstants.PAX_FLTR_FROM_STATION);
                for (String station: pFromStations) {
                    getStationFromList().add(new SelectionTO(station, 
                                                             station));
                    getStationToList().add(new SelectionTO(station, station));
                }

                //setDelayCodes((ArrayList<SelectionTO>)getDelegate().getDelayCodes());
                flightEditAccess = userPermissionTo.hasPermission(PrivileageConstants.PAX_TRG_UPLIFT,PrivileageConstants.PAX_ACT_EDIT);
                
               // System.out.println(" FLIGHT EDIT ACCESS ^^^^^^^^^^^^^^ "+flightEditAccess);
                
                
            } else {
                return "error";
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return "success";
    }
	
	private void getInboundAndOutboundDtls() throws FlightUpliftException {
	       // System.out.println(" Get Inbound and Outbound");
	        ArrayList<FlightTO> flightTOs;
	        /* retrieving inbound and outbound */
	        flightTOs = (ArrayList<FlightTO>)getFlightHandler().getUpliftFlightInfo(flightId);
	        //System.out.println(" @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@ ");
	        //System.out.println(" Flight count "+flightTOs.size());
	        
	        outFlightTO = flightTOs.get(0);
	        if(flightTOs.size() == 2) {
	            inFlightTO = flightTOs.get(1);
	        }
	        flightStatus = outFlightTO.getStatus();
	        //System.out.println(" FLIGHT STATUS ^^^^^^^^^^^^^^ "+flightStatus);
	        if(!PaxConstants.FLIGHT_STATUS_OPEN.equals(flightStatus))
	            flightEditAccess = false;
	}    
	
